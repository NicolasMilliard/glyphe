// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`react generator > generates stacked span components 1`] = `
"type SpinnerBrailleAnimationProps = {
  label?: string;
  decorative?: boolean;
  className?: string;
};

export function SpinnerBrailleAnimation({
  label = 'Loading',
  decorative = true,
  className,
}: SpinnerBrailleAnimationProps) {
  return (
    <>
      {decorative ? null : <span className="sr-only" role="status">{label}</span>}
      <span
        className={[ 'glyphe-spinner-braille', className ].filter(Boolean).join(' ')}
        aria-hidden={true}
      >
        <span>{'⠋'}</span>
        <span>{'⠙'}</span>
        <span>{'⠹'}</span>
        <span>{'⠸'}</span>
        <span>{'⠼'}</span>
        <span>{'⠴'}</span>
        <span>{'⠦'}</span>
        <span>{'⠧'}</span>
        <span>{'⠇'}</span>
        <span>{'⠏'}</span>
      </span>
    </>
  );
}

// Reduced motion: Prefer a single static frame when reduced motion is requested. Keep the generated CSS media query with this component."
`;

exports[`react generator > generates status components 1`] = `
"type ProgressAsciiAnimationProps = {
  label?: string;
  decorative?: boolean;
  className?: string;
};

export function ProgressAsciiAnimation({
  label = 'Progress loading',
  decorative = false,
  className,
}: ProgressAsciiAnimationProps) {
  return (
    <>
      {decorative ? null : <span className="sr-only" role="status">{label}</span>}
      <span
        className={[ 'glyphe-progress-ascii', className ].filter(Boolean).join(' ')}
        aria-hidden={decorative ? true : undefined}
      >
        <span>{'[>    ]'}</span>
        <span>{'[=>   ]'}</span>
        <span>{'[==>  ]'}</span>
        <span>{'[===> ]'}</span>
        <span>{'[====>]'}</span>
        <span>{'[=====]'}</span>
      </span>
    </>
  );
}

// Reduced motion: Prefer a readable static label when reduced motion is requested. Keep the generated CSS media query with this component."
`;

